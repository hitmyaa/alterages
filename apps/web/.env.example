# Supabase (projet dev)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Dashboard → Project Settings → API → "Publishable key"
# Format `sb_publishable_...` (nouveau standard Supabase). L'ancienne anon
# JWT key (eyJ...) reste également acceptée.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxx

# Utilisée uniquement côté serveur (Server Components, Route Handlers, middleware)
# NE JAMAIS exposer au client
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL publique du site (utilisée pour les OG tags, canonical, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — envoi du formulaire de contact (/api/contact)
# API key générée depuis https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Destinataire des emails du formulaire
CONTACT_EMAIL_TO=contact@alter-ages.fr
# Expéditeur (doit utiliser un domaine vérifié dans Resend)
CONTACT_EMAIL_FROM=AlterAges <noreply@alter-ages.fr>
